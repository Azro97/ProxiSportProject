# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'PP' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'PPTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # maplibre-react-native's podspec defines $MLRN.post_install, which
    # injects the actual MapLibre Native SDK as a Swift Package Manager
    # dependency (not a CocoaPods pod) into the Xcode project. Without
    # calling it here, that SPM package reference never gets added and the
    # wrapper code fails with "Module 'MapLibre' not found" even though
    # maplibre-react-native itself installs and compiles fine.
    $MLRN.post_install(installer)

    # Xcode 15+ made implicit C function declarations a hard error by
    # default (previously just a warning). Some pods - maplibre-react-native
    # in particular - predate that change and call C functions without a
    # full declaration in scope, which now fails the build. Downgrade back
    # to a warning across all pod targets rather than patching each
    # library's source individually.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_config|
        other_cflags = build_config.build_settings['OTHER_CFLAGS'] || ['$(inherited)']
        other_cflags = [other_cflags] if other_cflags.is_a?(String)
        other_cflags << '-Wno-error=implicit-function-declaration'
        build_config.build_settings['OTHER_CFLAGS'] = other_cflags
      end
    end
  end
end
